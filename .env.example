# =========================================================================
#                    MediFlow HMS Config Blueprint
# =========================================================================

# VITE_API_URL: Required for client SPA to talk to background endpoints when deployed on Vercel
# Point this to your Render custom Node/Express URL
VITE_API_URL="https://your-mediflow-backend.onrender.com"

# DATABASE_TYPE: Choose between local JSON database storage, Firebase Firestore or PostgreSQL/Supabase
DATABASE_TYPE="local"

# SUPABASE CONFIG: If migrating to PostgreSQL + Real-time (Supabase)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVC..."

# FIREBASE CONFIG: If migrating to Firebase Firestore Sync
FIREBASE_API_KEY="AIzaSyA..."
FIREBASE_AUTH_DOMAIN="your-app.firebaseapp.com"
FIREBASE_PROJECT_ID="your-app"
FIREBASE_STORAGE_BUCKET="your-app.appspot.com"
FIREBASE_MESSAGING_SENDER_ID="XXXXXXXXXXXX"
FIREBASE_APP_ID="1:XXXXX:web:XXXXX"

# SECURE JWT KEY: Key utilized to sign and certify patient authentication session keys on Render
JWT_SECRET="EnterYourRandomHexadecimalSymmetricKeyHere"
